{
  "manifest_version": 3,
  "name": "Houdini",
  "version": "0.4.1",
  "description": "Houdini brings Opera GX tab workspaces straight into Firefox's own sidebar. Pick a panel and every tab that doesn't belong disappears. Houdini would approve 🎩",
  "permissions": [
    "tabs",
    "tabHide",
    "sessions",
    "storage",
    "alarms",
    "menus",
    "tabGroups",
    "theme",
    "contextualIdentities",
    "cookies"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "houdini@local",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Switch Tab Panels",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
    }
  },
  "options_ui": {
    "page": "manage.html",
    "open_in_tab": true
  },
  "background": {
    "scripts": ["background.js"]
  },
  "commands": {
    "next-panel": {
      "suggested_key": { "default": "Alt+Period" },
      "description": "Switch to next panel"
    },
    "prev-panel": {
      "suggested_key": { "default": "Alt+Comma" },
      "description": "Switch to previous panel"
    },
    "_execute_action": {
      "suggested_key": { "default": "Alt+P" }
    },
    "take-snapshot": {
      "suggested_key": { "default": "Alt+S" },
      "description": "Take a snapshot now"
    },
    "switch-panel-1": { "description": "Switch to panel 1" },
    "switch-panel-2": { "description": "Switch to panel 2" },
    "switch-panel-3": { "description": "Switch to panel 3" },
    "switch-panel-4": { "description": "Switch to panel 4" },
    "switch-panel-5": { "description": "Switch to panel 5" },
    "switch-panel-6": { "description": "Switch to panel 6" },
    "switch-panel-7": { "description": "Switch to panel 7" },
    "switch-panel-8": { "description": "Switch to panel 8" }
  }
}
